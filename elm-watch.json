        },
        "Sandbox": {
            "inputs": ["test/Sandbox.elm"],
            "output": "test/Sandbox.elm.js"
        },
        "Worker": {
            "inputs": ["test/Worker.elm"],
            "output": "test/Worker.elm.js"
        }
    }
}
