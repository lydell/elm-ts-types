{
    "postprocess": ["elm-watch-node", "postprocess.js"],
    "targets": {
        "AllJson": {
            "inputs": ["test/AllJson.elm"],
            "output": "test/AllJson.elm.js"
        },
        "Application": {
            "inputs": ["test/Application.elm"],
            "output": "test/Application.elm.js"
        },
        "Document": {
            "inputs": ["test/Document.elm"],
            "output": "test/Document.elm.js"
        },
        "DocumentNoFlagsNoPorts": {
            "inputs": ["test/DocumentNoFlagsNoPorts.elm"],
            "output": "test/DocumentNoFlagsNoPorts.elm.js"
        },
        "Element": {
            "inputs": ["test/Element.elm"],
            "output": "test/Element.elm.js"
        },
        "ElementMaybeFlags": {
            "inputs": ["test/ElementMaybeFlags.elm"],
            "output": "test/ElementMaybeFlags.elm.js"
        },
        "ESM": {
            "inputs": ["test/ESM.elm"],
            "output": "test/ESM.elm.js"
        },
        "Html_": {
            "inputs": ["test/Html_.elm"],
